# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"
plugins=(git sudo extract colored-man-pages fzf)
source $ZSH/oh-my-zsh.sh

# External plugins
source $HOME/.zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
source $HOME/.zsh/plugins/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh

# History
HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000
setopt APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_VERIFY

# Prompt
eval "$(starship init zsh)"

# Search
alias h='history | grep'                         # search command history
alias f='find . | grep'                          # search files from current directory

# System
alias topcpu='ps -eo pid,user,pcpu,comm --sort=-pcpu | head'
alias topmem='ps -eo pid,user,pmem,comm --sort=-pmem | head'
alias da='date "+%Y-%m-%d %A %T %Z"'
alias cls='clear'

# Fedora maintenance
alias sdu='sudo dnf upgrade --refresh && flatpak update'
alias sda='sudo dnf autoremove'

# Safer file operations
alias cp='cp -i'
alias mv='mv -i'
alias del='trash -v'

# Navigation
alias ..='cd ..'
alias ...='cd ../..'

# File listing
alias ls='ls -Fh --color=always'                # colorized listing with type suffixes
alias la='ls -Alh'                               # detailed listing including hidden files
alias lsize='ls -lSrh'                           # sort by size
alias lext='ls -lXBh'                            # sort by extension
alias lfile="ls -l | egrep -v '^d'"              # files only
alias ldir="ls -l | egrep '^d'"                  # directories only
alias lsdu='du -h --max-depth=1'                 # sizes one level deep
alias treed='tree -CAFd'                         # directory tree only

# Tailscale
alias tsup='sudo systemctl start tailscaled && sudo tailscale up'
alias tsdown='sudo tailscale down && sudo systemctl stop tailscaled'
alias tsstatus='tailscale status'

# Apps
alias yazi='flatpak run io.github.sxyazi.yazi'

# Startup info
afetch
