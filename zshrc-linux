# Path to your Oh My Zsh installation
export ZSH="$HOME/.oh-my-zsh"

# Theme
ZSH_THEME="robbyrussell"

# Oh My Zsh plugins
plugins=(git sudo extract colored-man-pages fzf)

# Add extra completions before compinit
fpath=($HOME/.zsh/plugins/zsh-completions/src $fpath)

# Load Oh My Zsh
source $ZSH/oh-my-zsh.sh

# Completion system
autoload -Uz compinit
compinit

# External plugins
source $HOME/.zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
source $HOME/.zsh/plugins/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh

# Colors
autoload -U colors && colors

# History
HISTFILE=$HOME/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_VERIFY

# Better navigation
eval "$(zoxide init zsh)"

# Useful aliases
# alias ll='ls -lah'
# alias la='ls -A'
# alias l='ls -CF'

# Search
alias h="history | grep"        # search command line history
alias f="find . | grep"         # search files in current folder
alias topcpu='ps -eo pid,user,pcpu,comm --sort=-pcpu | head'
alias topmem='ps -eo pid,user,pmem,comm --sort=-pmem | head'

alias sdu='sudo dnf upgrade'
alias sda='sudo dnf autoremove'

alias cp='cp -i'
alias mv='mv -i'
alias del='trash -v'

alias home='cd ~'
alias ..='cd ..'
alias ...='cd ../..'

alias da='date "+%Y-%m-%d %A %T %Z"'

alias la='ls -Alh'                                      # show hidden files
alias lh='ls -A'                                        # show only hidden files
alias ls='ls -aFh --color=always'       # add colors and file type extensions
alias lsize='ls -lSrh'                          # sort by size
alias lext='ls -lXBh'                           # sort by extension
alias lfile="ls -l | egrep -v '^d'" # files only
alias ldir="ls -l | egrep '^d'"         # directories only
alias lsdu='du -h --max-depth=1'        # using du for ls to show size

alias treed='tree -CAFd' # displays directory tree

afetch
