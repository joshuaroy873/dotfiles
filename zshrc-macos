export ZSH="$HOME/.oh-my-zsh"
# ZSH_THEME="robbyrussell"

export PATH="/opt/homebrew/bin:$PATH"

plugins=(git sudo)

source $ZSH/oh-my-zsh.sh

source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

alias venv='source ~/venv/bin/activate'
alias jlab='source ~/venv/bin/activate && jupyter lab'

# Search
alias h="history | grep"	# search command line history
alias f="find . | grep"		# search files in current folder

alias cp='cp -i'
alias mv='mv -i'
alias del='trash -v'

alias ..='cd ..'
alias ...='cd ../..'

alias cls='clear'

alias da='date "+%Y-%m-%d %A %T %Z"'

# alias la='ls -Alh'					# show hidden files
# alias lh='ls -d .*'					# show only hidden files
# alias ls='ls -aFh'					# add colors and file type extensions
# alias lsize='ls -lSrh'				# sort by size
# alias lext='ls -lXBh'				# sort by extension
# alias lfile="ls -l | egrep -v '^d'" # files only
# alias ldir="ls -l | egrep '^d'"		# directories only
# alias lsdu='du -h -d 1'			 	# using du for ls to show size

alias treed='tree -CAFd' # displays directory tree

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

eval "$(starship init zsh)"
